{
  "type": "object",
  "required": ["claims", "summary"],
  "properties": {
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "type", "provenance", "evidence_sources", "unclassified_markers"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^C[0-9]{3,}$"
          },
          "text": {"type": "string"},
          "type": {
            "type": "string",
            "enum": [
              "fact",
              "inference",
              "evaluation",
              "decision",
              "open_question",
              "evidence_gap",
              "artifact_reference",
              "report_structure"
            ]
          },
          "provenance": {
            "type": "array",
            "items": {"type": "string"}
          },
          "evidence_sources": {
            "type": "array",
            "items": {"type": "string"}
          },
          "unclassified_markers": {
            "type": "array",
            "items": {"type": "string"}
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "section": {"type": "string"},
          "line": {"type": "integer"}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "claim_type_counts",
        "claims_with_unclassified_markers",
        "fact_count",
        "inference_count",
        "provenance_only_fact_ids",
        "uncited_fact_ids",
        "uncited_inference_ids"
      ],
      "properties": {
        "claim_type_counts": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        },
        "claims_with_unclassified_markers": {
          "type": "array",
          "items": {"type": "string"}
        },
        "fact_count": {"type": "integer"},
        "inference_count": {"type": "integer"},
        "provenance_only_fact_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "uncited_fact_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "uncited_inference_ids": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
