{
  "type": "object",
  "required": [
    "stage",
    "summary",
    "facts",
    "inferences",
    "uncertainties",
    "evidence_gaps",
    "preliminary_disagreements",
    "source_evaluation",
    "sources"
  ],
  "properties": {
    "stage": {"type": "string", "enum": ["research-a", "research-b"]},
    "summary": {"type": "array"},
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "evidence_sources"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "evidence_sources": {"type": "array", "items": {"type": "string"}},
          "support_links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_id", "role"],
              "properties": {
                "source_id": {"type": "string"},
                "role": {"type": "string", "enum": ["evidence", "context", "challenge", "provenance"]}
              }
            }
          },
          "claim_dependencies": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "inferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "evidence_sources", "confidence"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "evidence_sources": {"type": "array", "items": {"type": "string"}},
          "support_links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_id", "role"],
              "properties": {
                "source_id": {"type": "string"},
                "role": {"type": "string", "enum": ["evidence", "context", "challenge", "provenance"]}
              }
            }
          },
          "claim_dependencies": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "string", "enum": ["low", "medium", "high"]}
        }
      }
    },
    "uncertainties": {"type": "array"},
    "evidence_gaps": {"type": "array"},
    "preliminary_disagreements": {"type": "array"},
    "source_evaluation": {"type": "array"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "authority", "locator"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "type": {"type": "string"},
          "authority": {"type": "string"},
          "locator": {"type": "string"},
          "source_class": {
            "type": "string",
            "enum": ["external_evidence", "job_input", "workflow_provenance", "recovered_provisional"]
          },
          "acquisition_provenance": {"type": "string"}
        }
      }
    }
  }
}
