{
  "type": "object",
  "required": [
    "stage",
    "supported_conclusions",
    "synthesis_judgments",
    "unresolved_disagreements",
    "confidence_assessment",
    "evidence_gaps",
    "rationale",
    "recommended_artifact_structure",
    "sources"
  ],
  "properties": {
    "stage": {"type": "string", "enum": ["judge"]},
    "supported_conclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "evidence_sources"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "evidence_sources": {"type": "array", "items": {"type": "string"}},
          "support_links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_id", "role"],
              "properties": {
                "source_id": {"type": "string"},
                "role": {"type": "string", "enum": ["evidence", "context", "challenge", "provenance"]}
              }
            }
          },
          "claim_dependencies": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "synthesis_judgments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "evidence_sources", "confidence"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "evidence_sources": {"type": "array", "items": {"type": "string"}},
          "support_links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_id", "role"],
              "properties": {
                "source_id": {"type": "string"},
                "role": {"type": "string", "enum": ["evidence", "context", "challenge", "provenance"]}
              }
            }
          },
          "claim_dependencies": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "string", "enum": ["low", "medium", "high"]}
        }
      }
    },
    "unresolved_disagreements": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": {"type": "string"}
            }
          },
          {
            "type": "object",
            "required": ["point", "case_a", "case_b", "reason_unresolved"],
            "properties": {
              "point": {"type": "string"},
              "case_a": {"type": "string"},
              "case_b": {"type": "string"},
              "reason_unresolved": {"type": "string"}
            }
          }
        ]
      }
    },
    "confidence_assessment": {
      "oneOf": [
        {"type": "string"},
        {"type": "array"},
        {
          "type": "object",
          "required": ["summary"],
          "properties": {
            "summary": {"type": "string"},
            "topics": {
              "type": "array",
              "items": {
                "oneOf": [
                  {"type": "string"},
                  {
                    "type": "object",
                    "required": ["topic", "rationale"],
                    "properties": {
                      "topic": {"type": "string"},
                      "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
                      "rationale": {"type": "string"}
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "evidence_gaps": {
      "oneOf": [
        {"type": "string"},
        {"type": "array"}
      ]
    },
    "rationale": {
      "oneOf": [
        {"type": "string"},
        {"type": "array"}
      ]
    },
    "recommended_artifact_structure": {
      "oneOf": [
        {"type": "string"},
        {"type": "array"},
        {
          "type": "object",
          "required": ["sections"],
          "properties": {
            "sections": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      ]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "authority", "locator"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "type": {"type": "string"},
          "authority": {"type": "string"},
          "locator": {"type": "string"},
          "source_class": {
            "type": "string",
            "enum": ["external_evidence", "job_input", "workflow_provenance", "recovered_provisional"]
          },
          "acquisition_provenance": {"type": "string"}
        }
      }
    }
  }
}
